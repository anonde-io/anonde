FROM golang:1.26-alpine AS build
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/platform ./cmd/platform

FROM gcr.io/distroless/static-debian12
COPY --from=build /out/platform /platform
EXPOSE 8080
ENTRYPOINT ["/platform"]

